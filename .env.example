# Copy to .env for LOCAL testing only. The server reads process.env directly
# (it does NOT auto-load .env). To use this file locally, launch with Node's
# built-in flag:   node --env-file=.env dist/index.js
# In normal use the key is set in your MCP client's config `env`, not here.

# ---- USPTO Open Data Portal (ODP) ----
# The one credential this server needs. Register free at account.uspto.gov
# (sign in / verify with ID.me) -> Manage API Key. One ODP key covers the
# continuity + application endpoints used here (sent as the x-api-key header).
USPTO_API_KEY=

# ---- Optional tuning ----
# Default UI language for charts + text output: en (default) or zh.
# PATENT_FAMILY_LANG=en
# HTTP timeout in milliseconds (default 30000).
# PATENT_HTTP_TIMEOUT_MS=30000
# Disk cache for ODP responses: set to 0 to disable (default on, 7-day TTL).
# PATENT_ODP_CACHE=1
# Python executable used to render charts (default python3).
# PATENT_PYTHON=python3
